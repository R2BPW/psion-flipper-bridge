INCLUDE "SYSTEM.OXH"

REM PSMACS IR Chat v5 - Tight ternary (base-3)
REM
REM Start-per-char ternary with tighter gap timing.
REM 4 bursts per char (start + 3 digits).
REM
REM Gap timing:
REM   Start:   PAUSE 26 = 1300ms  (gap ~2255ms)
REM   Digit 0: PAUSE 4  = 200ms   (gap ~1155ms)
REM   Digit 1: PAUSE 8  = 400ms   (gap ~1355ms)
REM   Digit 2: PAUSE 12 = 600ms   (gap ~1555ms)

PROC Main:
  LOCAL msg$(255)
  LOCAL i%, ch%, code%

  FONT 11,0
  PRINT "IR Chat v5 (TerTight)"
  PRINT "====================="
  PRINT ""

again::
  PRINT "Msg (A-Z, space):"
  INPUT msg$
  IF msg$ = ""
    RETURN
  ENDIF
  msg$ = UPPER$(msg$)

  PRINT "Sending: "; msg$

  i% = 1
  WHILE i% <= LEN(msg$)
    ch% = ASC(MID$(msg$, i%, 1))
    IF ch% >= 65 AND ch% <= 90
      code% = ch% - 65
    ELSEIF ch% = 32
      code% = 26
    ELSE
      code% = -1
    ENDIF
    IF code% >= 0
      TerSendChar:(code%)
      PRINT MID$(msg$, i%, 1);
    ENDIF
    i% = i% + 1
  ENDWH

  REM End marker
  IrFlash:
  PAUSE 40

  PRINT ""
  PRINT "Sent."

  PRINT "Waiting for reply..."
  Recv:
  PRINT ""

  GOTO again
ENDP

PROC TerSendChar:(code%)
  LOCAL d0%, d1%, d2%
  LOCAL rem%

  d2% = code% / 9
  rem% = code% - (d2% * 9)
  d1% = rem% / 3
  d0% = rem% - (d1% * 3)

  REM Start burst + 1300ms gap (ternary marker)
  IrFlash:
  PAUSE 26

  REM Digit 2 (most significant)
  IrFlash:
  TerPause:(d2%)

  REM Digit 1
  IrFlash:
  TerPause:(d1%)

  REM Digit 0 (least significant)
  IrFlash:
  TerPause:(d0%)
ENDP

PROC TerPause:(digit%)
  IF digit% = 0
    PAUSE 4
  ELSEIF digit% = 1
    PAUSE 8
  ELSE
    PAUSE 12
  ENDIF
ENDP

PROC IrFlash:
  LOCAL ret&
  ONERR skip
  ret& = IrDAConnectToSend&:(KIrTinyTP$, 1)
  skip::
  ONERR OFF
  ONERR skip2
  IrDADisconnect:
  skip2::
  ONERR OFF
ENDP

PROC Recv:
  LOCAL sr%(6), d%
  LOCAL buf$(1)
  LOCAL pbuf&, ln%
  LOCAL v%, state%, byte%, bitn%
  LOCAL reply$(255)
  LOCAL rch$(1)
  LOCAL tries%

  tries% = 1
  WHILE tries% <= 15
    ONERR tryagain
    LOPEN "TTY:B"
    ONERR OFF
    GOTO portok
    tryagain::
    ONERR OFF
    PRINT ".";
    PAUSE 100
    tries% = tries% + 1
  ENDWH
  PRINT ""
  PRINT "(TTY:B busy)"
  RETURN

  portok::
  sr%(1) = 13 + 13*256
  sr%(2) = 3
  sr%(3) = 0
  sr%(4) = 0
  sr%(5) = 0
  sr%(6) = 0
  IOW(-1, 7, sr%(1), d%)

  pbuf& = ADDR(buf$) + 1
  ln% = 1
  state% = 0
  byte% = 0
  bitn% = 0
  reply$ = ""

  PRINT "Listening..."

  DO
    d% = IOW(-1, 1, #pbuf&, ln%)
    IF d% >= 0
      v% = PEEKB(pbuf&) AND 255

      IF state% = 0
        IF v% > $90 AND v% < $E0
          state% = 1
          byte% = 0
          bitn% = 0
        ENDIF
      ELSEIF state% = 1
        IF v% >= $E0
          byte% = byte% * 2 + 1
          bitn% = bitn% + 1
        ELSEIF v% <= $90
          byte% = byte% * 2
          bitn% = bitn% + 1
        ELSE
          LCLOSE
          PRINT ""
          IF LEN(reply$) > 0
            PRINT "LLM: "; reply$
          ELSE
            PRINT "(empty)"
          ENDIF
          RETURN
        ENDIF
        IF bitn% = 8
          IF byte% = 4
            LCLOSE
            PRINT ""
            IF LEN(reply$) > 0
              PRINT "LLM: "; reply$
            ELSE
              PRINT "(empty)"
            ENDIF
            RETURN
          ENDIF
          IF byte% >= 32 AND byte% <= 126
            rch$ = CHR$(byte%)
            reply$ = reply$ + rch$
            PRINT rch$;
          ENDIF
          byte% = 0
          bitn% = 0
        ENDIF
      ENDIF
    ENDIF
  UNTIL 0
ENDP
