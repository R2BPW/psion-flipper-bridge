INCLUDE "SYSTEM.OXH"

CONST KUidOpxIrFlash& = &101F9B01
CONST KOpxIrFlashVersion% = $0100

DECLARE OPX IRFLASH,KUidOpxIrFlash&,KOpxIrFlashVersion%
  IrInit%: : 1
  IrFlash%: : 2
  IrClose%: : 3
  IrSetSlots%:(n%) : 4
END DECLARE

REM PSMACS IR Chat v7 - OPX fast burst
REM
REM Uses native IrFlash OPX for ~5-10x faster IR bursts.
REM IrFlash OPX uses IrDA sockets with 1 discovery slot,
REM bypassing full IrDA discovery overhead.
REM
REM Expected: ~100-200ms per burst vs ~955ms with OPL IrDA.
REM Ternary encoding: 4 bursts per char.
REM
REM Gap timing (calibrated from gaps_001 data):
REM   Start:   PAUSE 13 = 650ms  (gap ~680ms, OPX start >= 550)
REM   Digit 0: PAUSE 4  = 200ms  (gap ~230ms, d0 < 300)
REM   Digit 1: PAUSE 7  = 350ms  (gap ~380ms, d1 300-399)
REM   Digit 2: PAUSE 9  = 450ms  (gap ~480ms, d2 400-549)
REM
REM NOTE: Flipper thresholds need recalibration for these
REM faster gaps. Run test mode first to measure actual gaps.

PROC Main:
  LOCAL msg$(255)
  LOCAL i%, ch%, code%
  LOCAL d0%, d1%, d2%, rem%
  LOCAL err%
  LOCAL k$(8)

  FONT 11,0
  PRINT "IR Chat v7 (OPX)"
  PRINT "================"
  PRINT ""

  PRINT "Init IrFlash OPX..."
  err% = IrInit%:
  IF err% < 0
    PRINT "IrInit failed: "; err%
    RETURN
  ENDIF
  PRINT "OPX ready (port "; err%; ")"
  PRINT ""

again::
  PRINT "Msg (A-Z, space):"
  INPUT msg$
  IF msg$ = ""
    GOTO cleanup
  ENDIF
  msg$ = UPPER$(msg$)

  PRINT "Sending: "; msg$

  i% = 1
  WHILE i% <= LEN(msg$)
    ch% = ASC(MID$(msg$, i%, 1))
    IF ch% >= 65 AND ch% <= 90
      code% = ch% - 65
    ELSEIF ch% = 32
      code% = 26
    ELSE
      code% = -1
    ENDIF
    IF code% >= 0
      REM Decompose into base-3
      d2% = code% / 9
      rem% = code% - (d2% * 9)
      d1% = rem% / 3
      d0% = rem% - (d1% * 3)

      REM Start burst + gap
      err% = IrFlash%:
      PAUSE 13

      REM Digit 2
      err% = IrFlash%:
      TerPause:(d2%)

      REM Digit 1
      err% = IrFlash%:
      TerPause:(d1%)

      REM Digit 0
      err% = IrFlash%:
      TerPause:(d0%)

      PRINT MID$(msg$, i%, 1);
    ENDIF
    i% = i% + 1
  ENDWH

  REM Final burst: completes last char's d0 digit
  err% = IrFlash%:

  REM Silence for message timeout
  PAUSE 40

  PRINT ""
  PRINT "Sent."

  REM Close OPX port before RX (avoids TTY:B conflict)
  err% = IrClose%:

  PRINT "Waiting for reply..."
  Recv:
  PRINT ""

  REM Re-open OPX port for next TX
  err% = IrInit%:
  IF err% < 0
    PRINT "IrInit failed: "; err%
    RETURN
  ENDIF

  GOTO again

  cleanup::
  err% = IrClose%:
  PRINT "Done."
ENDP

PROC TerPause:(digit%)
  IF digit% = 0
    PAUSE 4
  ELSEIF digit% = 1
    PAUSE 7
  ELSE
    PAUSE 9
  ENDIF
ENDP

PROC Recv:
  LOCAL sr%(6), d%
  LOCAL buf$(1)
  LOCAL pbuf&, ln%
  LOCAL v%, state%, byte%, bitn%
  LOCAL reply$(255)
  LOCAL rch$(1)
  LOCAL tries%

  tries% = 1
  WHILE tries% <= 15
    ONERR tryagain
    LOPEN "TTY:B"
    ONERR OFF
    GOTO portok
    tryagain::
    ONERR OFF
    PRINT ".";
    PAUSE 100
    tries% = tries% + 1
  ENDWH
  PRINT ""
  PRINT "(TTY:B busy)"
  RETURN

  portok::
  sr%(1) = 13 + 13*256
  sr%(2) = 3
  sr%(3) = 0
  sr%(4) = 0
  sr%(5) = 0
  sr%(6) = 0
  IOW(-1, 7, sr%(1), d%)

  pbuf& = ADDR(buf$) + 1
  ln% = 1
  state% = 0
  byte% = 0
  bitn% = 0
  reply$ = ""

  PRINT "Listening..."

  DO
    d% = IOW(-1, 1, #pbuf&, ln%)
    IF d% >= 0
      v% = PEEKB(pbuf&) AND 255

      IF state% = 0
        IF v% > $90 AND v% < $E0
          state% = 1
          byte% = 0
          bitn% = 0
        ENDIF
      ELSEIF state% = 1
        IF v% >= $E0
          byte% = byte% * 2 + 1
          bitn% = bitn% + 1
        ELSEIF v% <= $90
          byte% = byte% * 2
          bitn% = bitn% + 1
        ELSE
          LCLOSE
          PRINT ""
          IF LEN(reply$) > 0
            PRINT "LLM: "; reply$
          ELSE
            PRINT "(empty)"
          ENDIF
          RETURN
        ENDIF
        IF bitn% = 8
          IF byte% = 4
            LCLOSE
            PRINT ""
            IF LEN(reply$) > 0
              PRINT "LLM: "; reply$
            ELSE
              PRINT "(empty)"
            ENDIF
            RETURN
          ENDIF
          IF byte% >= 32 AND byte% <= 126
            rch$ = CHR$(byte%)
            reply$ = reply$ + rch$
            PRINT rch$;
          ENDIF
          byte% = 0
          bitn% = 0
        ENDIF
      ENDIF
    ENDIF
  UNTIL 0
ENDP
